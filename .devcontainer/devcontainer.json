{
  "name": "Java DevContainer",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Monta seu projeto local dentro do container
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",

  // Encaminha a porta do Spring Boot
  "forwardPorts": [8083],
  "portsAttributes": {
    "8083": {
      "label": "Spring Boot",
      "onAutoForward": "openBrowser"
    }
  },

  // Extensões essenciais
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack",
        "vscjava.vscode-lombok",
        "eamodio.gitlens"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-21",
            "path": "/opt/java/openjdk",
            "default": true
          }
        ],
        "java.import.gradle.enabled": true,
        "java.maven.downloadSources": true,
        "java.jdt.ls.java.home": "/opt/java/openjdk"
      }
    }
  },

  // Valida ferramentas após subir o container
  "postCreateCommand": "java -version && mvn -v",

  //"remoteUser": "root"
}
